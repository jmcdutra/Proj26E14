        <mxCell id="titulo" value="&lt;b&gt;Arquitetura da Solução — Sistema de Gestão de Biblioteca Universitária&lt;/b&gt;&lt;br/&gt;Aplicação de terminal em Java — Diagrama de Classes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=13;align=center;" vertex="1" parent="1">
